{
  "name": "etn-migration-tool",
  "version": "2.0.2",
  "description": "Electroneum Legacy Chain to Smart Chain Migration Tool",
  "author": {
    "name": "Electroneum",
    "email": "chris.harrison@electroneum.com"
  },
  "homepage": "https://electroneum.com",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build:mac:macos14": "BIN_VARIANT_DIR=mac-arm64-macos14 MAC_VARIANT_LABEL=macos14 electron-vite build && BIN_VARIANT_DIR=mac-arm64-macos14 MAC_VARIANT_LABEL=macos14 electron-builder --mac",
    "build:mac:macos15": "BIN_VARIANT_DIR=mac-arm64-macos15 MAC_VARIANT_LABEL=macos15 electron-vite build && BIN_VARIANT_DIR=mac-arm64-macos15 MAC_VARIANT_LABEL=macos15 electron-builder --mac",
    "build:mac:all": "npm run build:mac:macos14 && npm run build:mac:macos15",
    "build:linux": "BIN_VARIANT_DIR=linux-x64 electron-vite build && BIN_VARIANT_DIR=linux-x64 electron-builder --linux",
    "build:win": "BIN_VARIANT_DIR=win-x64 electron-vite build && BIN_VARIANT_DIR=win-x64 electron-builder --win",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "ctrlc-windows": "^2.2.0",
    "ethereum-cryptography": "^2.1.2",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.electroneum.migration-tool",
    "productName": "ETN Migration Tool",
    "directories": {
      "buildResources": "resources"
    },
    "extraResources": [
      {
        "from": "bin/${env.BIN_VARIANT_DIR}/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/pdfkit/**",
      "node_modules/fontkit/**",
      "node_modules/linebreak/**"
    ],
    "icon": "resources/icon",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.finance",
      "identity": null,
      "artifactName": "${productName}-${version}-${env.MAC_VARIANT_LABEL}-arm64.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
